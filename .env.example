# ============================================
# AE Reverse Assistant - 环境配置
# ============================================

# DashScope API Key (通义千问 + Embedding)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# API Base URL (ideaTalk / DashScope)
API_BASE_URL=https://idealab.alibaba-inc.com/api/openai/v1

# LLM Model (optional, default: qwen-plus)
LLM_MODEL=qwen-plus

# 模型降级列表（逗号分隔，主模型额度不足时自动切换）
# 按质量从高到低排列，覆盖百炼平台所有有免费额度的主流模型
LLM_MODEL_FALLBACK=qwen3.7-max,qwen3.7-max-preview,qwen3-max,qwen-max,qwen3-235b-a22b,deepseek-v3,deepseek-v3.2,qwen3.6-plus,qwen3.5-plus,qwen3.6-flash,qwen-turbo,qwen-long,qwen3-vl-plus,glm-5,glm-4.7,glm-4.6,glm-4.5,kimi-k2.5,kimi-k2.6,MiniMax-M2.5,MiniMax-M2.1,qwq-plus,qwen3-32b,qwen3.5-27b,qwen3-14b,qwen3-8b,qwen-vl-plus,qwen-vl-ocr

# Embedding Model (optional, default: text-embedding-v1)
# 注：text-embedding-v3 输出 1024 维，v1 输出 1536 维，切换模型后缓存会自动失效重建
EMBEDDING_MODEL=text-embedding-v1

# 知识库本地路径 (支持 Markdown/TXT/PDF/Word 文件或目录)
KNOWLEDGE_BASE_PATH=./knowledge

# 钉钉文档 API (可选)
DINGTALK_ACCESS_TOKEN=your_dingtalk_access_token_here
DINGTALK_DOC_IDS=doc_id_1,doc_id_2

# 服务配置
PORT=3000
LOG_LEVEL=info