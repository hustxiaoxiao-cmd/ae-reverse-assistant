#!/bin/bash
# FC Custom Runtime 入口脚本
# 由 FC 自动调用，启动 Express 服务

set -euo pipefail

# FC 要求监听 9000 端口
export PORT=9000

echo "[bootstrap] Starting ae-reverse-assistant..."
echo "[bootstrap] PORT=$PORT"
echo "[bootstrap] NODE_ENV=${NODE_ENV:-production}"
echo "[bootstrap] Working directory: $(pwd)"

# 执行编译后的 JS（比 ts-node 冷启动更快）
exec node dist/index.js
