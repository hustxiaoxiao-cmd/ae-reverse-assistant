    "pino-pretty": "^13.1.3",
    "ts-node": "^10.4.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.13",
    "@types/jest": "^29.5.14",
    "@types/node": "^16.11.7",
    "@types/uuid": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.0.0",
    "typescript": "~5.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/ae-reverse-assistant.git"
